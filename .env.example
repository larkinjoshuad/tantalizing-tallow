# Shopify Storefront API
# 1. Shopify Admin → Settings → Apps → Develop apps → Create app
# 2. Configure Storefront API scopes:
#    - unauthenticated_read_product_listings
#    - unauthenticated_read_product_tags
#    - unauthenticated_write_checkouts
#    - unauthenticated_read_checkouts
# 3. Install app → Copy Storefront access token here

VITE_SHOPIFY_DOMAIN=tantalizingtallow.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
